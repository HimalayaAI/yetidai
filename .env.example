DISCORD_TOKEN=your_discord_bot_token_here

# LLM backend: "haiku" (default, local via `claude` CLI) or "sarvam"
YETI_BACKEND=haiku

# Haiku backend options (used when YETI_BACKEND=haiku)
YETI_HAIKU_MODEL=haiku
YETI_HAIKU_EFFORT=low
YETI_HAIKU_TIMEOUT=90

# Sarvam backend options (used when YETI_BACKEND=sarvam)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_ROUTER_MODEL=sarvam-30b
SARVAM_ROUTER_TIMEOUT_SECONDS=1.5
NEPALOSINT_BASE_URL=https://nepalosint.com/api/v1
NEPALOSINT_PUBLIC_AUTH_ENABLED=true
NEPALOSINT_TIMEOUT_SECONDS=8
NEPALOSINT_MAX_CONTEXT_ITEMS=8


INTRO_CHANNEL_ID=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_PRIVATE_KEY=