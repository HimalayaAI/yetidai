DISCORD_TOKEN=your_discord_bot_token_here

# Sarvam backend (required)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_ROUTER_MODEL=sarvam-30b
SARVAM_ROUTER_TIMEOUT_SECONDS=1.5
# Hard per-call timeout for Sarvam chat completions (seconds).
SARVAM_TIMEOUT_SECONDS=25

# NepalOSINT configuration
NEPALOSINT_BASE_URL=https://nepalosint.com/api/v1
NEPALOSINT_PUBLIC_AUTH_ENABLED=true
NEPALOSINT_TIMEOUT_SECONDS=8
NEPALOSINT_MAX_CONTEXT_ITEMS=8


INTRO_CHANNEL_ID=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_PRIVATE_KEY=