// YetiDai end-to-end flow: Discord user message → Sarvam (primary) → tools → final Nepali answer.
// Render: dot -Tpng docs/flowchart.dot -o docs/flowchart.png
digraph YetiDaiFlow {
  rankdir=TB;
  graph [bgcolor="#0e1116", fontname="Helvetica", fontsize=14, splines=spline,
         nodesep=0.55, ranksep=0.95, pad=0.6, dpi=180, size="24,30",
         labelloc=t, label=<<b><font color="#F6F7F9" point-size="22">YetiDai — Discord → Sarvam AI → NepalOSINT → final Nepali answer</font></b>>];
  node  [fontname="Helvetica", fontsize=12, style="filled,rounded", shape=box,
         color="#404854", fontcolor="#F6F7F9", penwidth=1.4, margin="0.20,0.12"];
  edge  [fontname="Helvetica", fontsize=10, color="#8A9BA8", fontcolor="#C5CBD3", penwidth=1.2];

  // ── Entry ──────────────────────────────────────────────
  user      [label=<<b>Discord user message</b><br/>Nepali / English / Romanized>,
             fillcolor="#1C2127", shape=note];

  botctx    [label=<<b>bot.py :: on_message</b><br align="left"/>
• fetch last 5 channel messages as history<br align="left"/>
• build dynamic_system_prompt<br align="left"/>
  (systemPrompt.txt + today's date)<br align="left"/>
• messages = [system, …history, user]<br align="left"/>
• tools = registry.openai_tools()<br align="left"/>>,
             fillcolor="#1C2127"];

  // ── LLM ────────────────────────────────────────────────
  subgraph cluster_llm {
    label=<<b><font color="#8ABBFF">Sarvam AI — tool-calling loop (up to MAX_TOOL_ROUNDS = 5)</font></b>>;
    style="rounded,dashed"; color="#2D72D2"; bgcolor="#141923";

    sarvam    [label=<<b>Sarvam AI</b><br/>
AsyncSarvamAI — model=<b>sarvam-30b</b><br align="left"/>
native OpenAI-style tool_calling<br align="left"/>
tool_choice="auto"<br align="left"/>
env: SARVAM_API_KEY<br align="left"/>>,
               fillcolor="#1F4B99", fontcolor="#FFFFFF", color="#2D72D2", penwidth=2.5];

    decide    [label=<<b>finish_reason?</b>>, shape=diamond,
               fillcolor="#2D72D2", fontcolor="#ffffff", penwidth=2];
  }

  // ── Decision buckets ───────────────────────────────────
  b1        [label=<<b>Bucket 1  —  Greeting / chit-chat</b><br/>
नमस्ते • hey • तिमी को हौ?<br align="left"/>
<b>→ MODE B, no tool</b><br align="left"/>>, fillcolor="#0A6640", fontcolor="#FFFFFF"];

  b2        [label=<<b>Bucket 2  —  Nepal factual</b><br/>
PM, ministers, NEPSE, inflation,<br align="left"/>
parliament, debt, news, historical dates<br align="left"/>
<b>→ get_nepal_live_context(focus)</b><br align="left"/>>, fillcolor="#1F4B99", fontcolor="#FFFFFF"];

  b3        [label=<<b>Bucket 3  —  Non-Nepal world</b><br/>
UEFA, FIFA, foreign PM, global CEOs<br align="left"/>
<b>→ internet_search(query)</b><br align="left"/>>, fillcolor="#8F398F", fontcolor="#FFFFFF"];

  // ── internet_search branch ─────────────────────────────
  subgraph cluster_search {
    label=<<b><font color="#D77CC8">tools/search/plugin.py</font></b>>;
    style="rounded,dashed"; color="#9D3F9D"; bgcolor="#141923";
    ddg       [label=<<b>DuckDuckGo HTML scrape</b><br/>
BeautifulSoup, ≤5 snippets<br align="left"/>
User-Agent: Chrome<br align="left"/>>, fillcolor="#252A31"];
    snippets  [label=<English snippets + source URLs<br/><i>(to be translated into Nepali)</i>>,
               fillcolor="#252A31"];
  }

  // ── OSINT branch ───────────────────────────────────────
  subgraph cluster_osint {
    label=<<b><font color="#FFB366">tools/osint/plugin.py  —  get_nepal_live_context</font></b>>;
    style="rounded,dashed"; color="#C87619"; bgcolor="#141923";

    planner   [label=<<b>retrieval_planner.resolve_route_plan</b><br/>
LLM-assisted intent rewrite<br align="left"/>
focus → canonical category<br align="left"/>>, fillcolor="#1C2127"];

    router    [label=<<b>context_router.route_query</b><br/>returns RoutePlan>, fillcolor="#252A31"];

    date_x    [label=<<b>_extract_history_range()</b><br/>
• ISO '2026-02-28'<br align="left"/>
• English months 'feb 28', '28 february 2026'<br align="left"/>
• Devanagari 'फेब्रुअरी २८' (digit-aware)<br align="left"/>
• Relative Nepali 'हिजो', 'गत हप्ता'<br align="left"/>
• Romanized 'hijo', 'gaeko hapta'<br align="left"/>
→ (start_dt, end_dt)<br align="left"/>>, fillcolor="#252A31"];

    intents   [label=<<b>Intent keywords</b><br/>
MACRO • NEPSE • DEBT • GOVT<br align="left"/>
PARLIAMENT • ANNOUNCEMENTS<br align="left"/>
TOURISM • TRADE • WHO_IS<br align="left"/>
GENERAL_NEWS<br align="left"/>>, fillcolor="#252A31"];

    plan      [label=<<b>RoutePlan</b><br/>
use_nepalosint, intents{},<br align="left"/>
is_who_is, history_range?,<br align="left"/>
history_category<br align="left"/>  (economic | political)<br align="left"/>>,
               fillcolor="#1F4B99", fontcolor="#FFFFFF"];
  }

  // ── NepalOSINT endpoints ───────────────────────────────
  subgraph cluster_fetch {
    label=<<b><font color="#72CA9B">fetch_context_bundle  —  asyncio.gather parallel NepalOSINT calls</font></b>>;
    style="rounded,dashed"; color="#238551"; bgcolor="#141923";

    fetch     [label=<<b>fetch_context_bundle</b><br/>
NepalOSINTClient (httpx)<br align="left"/>
base_url=nepalosint.com/api/v1<br align="left"/>
bearer token via /auth/public<br align="left"/>>, fillcolor="#1C2127"];

    ep1       [label=<<b>/economy/snapshot</b><br/>NRB macro: inflation, FX,<br/>remittance, reserves, trade, tourism>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep2       [label=<<b>/dashboard/bootstrap</b><br/>preset=economy / security / politics>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep3       [label=<<b>/govt/decisions/latest</b><br/>cabinet decisions, deduped>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep4       [label=<<b>/govt/announcements/summary</b><br/>ministry notices>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep5       [label=<<b>/debt/clock</b><br/>PDMO real-time debt/GDP>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep6       [label=<<b>/parliament/verbatim/summary</b><br/>session summaries>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep7       [label=<<b>/parliament/bills</b><br/>bill tracker with status>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep8       [label=<<b>/search/unified</b><br/>cross-source keyword search>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep9       [label=<<b>/search/embeddings</b><br/>semantic similarity>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep10      [label=<<b>/consolidated/recent</b><br/>last 24h stories>, fillcolor="#0A6640", fontcolor="#FFFFFF"];
    ep11      [label=<<b>/consolidated/history</b><br/>?start=…&amp;end=…<br/>historical date-range stories>, fillcolor="#0A6640", fontcolor="#FFFFFF"];

    bundle    [label=<<b>context_bundle</b><br/>payloads{endpoint→json}<br align="left"/>sources[]<br align="left"/>>,
               fillcolor="#1F4B99", fontcolor="#FFFFFF"];
  }

  formatter [label=<<b>context_formatter.build_context_brief</b><br/>
compress payloads → Nepali-friendly brief<br align="left"/>
cap at max_chars=1800<br align="left"/>
append SOURCES: line<br align="left"/>
[NEPALOSINT_FETCH_FAILED] if empty<br align="left"/>>, fillcolor="#C87619", fontcolor="#FFFFFF"];

  toolmsg   [label=<<b>ToolResult → role:"tool" message</b><br/>appended to messages[]<br align="left"/>loop back to LLM<br align="left"/>>, fillcolor="#252A31"];

  // ── Final answer ───────────────────────────────────────
  finalize  [label=<<b>LLM final turn (MODE B)</b><br/>
reads TOOL_RESULT in transcript<br align="left"/>
writes Nepali answer:<br align="left"/>
• translate English snippets<br align="left"/>
• digits → Devanagari (४.८२%)<br align="left"/>
• polite tone (तपाईं, हजुर)<br align="left"/>
• end with <b>स्रोत:</b> 2–4 citations<br align="left"/>>,
             fillcolor="#1F4B99", fontcolor="#FFFFFF"];

  fallback  [label=<<b>Graceful fallback</b><br/>
"माफ गर्नुहोस्, यो विषयमा अहिले<br align="left"/>
भरपर्दो जानकारी भेटिएन…"<br align="left"/>
<i>no training-data guesses</i><br align="left"/>>,
             fillcolor="#5C2223", fontcolor="#FFC0C0"];

  chunker   [label=<<b>Discord send</b><br/>chunk ≤2000 chars<br align="left"/>channel.send() loop<br align="left"/>>,
             fillcolor="#252A31"];

  discord   [label=<<b>Discord reply</b><br/>Nepali Devanagari>, fillcolor="#1C2127", shape=note];

  // ── Edges ──────────────────────────────────────────────
  user     -> botctx;
  botctx   -> sarvam [penwidth=2];

  sarvam   -> decide [penwidth=2];

  decide   -> b1 [label="stop\n(no tool_calls)"];
  decide   -> b2 [label="tool_calls →\nget_nepal_live_context", penwidth=2];
  decide   -> b3 [label="tool_calls →\ninternet_search"];

  b1       -> chunker;

  b3       -> ddg -> snippets -> toolmsg;

  b2       -> planner -> router -> date_x -> intents -> plan;
  plan     -> fetch;
  fetch    -> ep1  [label="macro"];
  fetch    -> ep2  [label="dashboard"];
  fetch    -> ep3  [label="govt"];
  fetch    -> ep4  [label="announcements"];
  fetch    -> ep5  [label="debt"];
  fetch    -> ep6  [label="parliament\nverbatim"];
  fetch    -> ep7  [label="bills"];
  fetch    -> ep8  [label="who_is /\nunified"];
  fetch    -> ep9  [label="who_is /\nsemantic"];
  fetch    -> ep10 [label="general_news\n(no date)"];
  fetch    -> ep11 [label="general_news +\nhistory_range"];
  {ep1 ep2 ep3 ep4 ep5 ep6 ep7 ep8 ep9 ep10 ep11} -> bundle;
  bundle   -> formatter -> toolmsg;

  toolmsg  -> decide [label="next round\n(≤5 total)", style=dashed, color="#8ABBFF", constraint=false];

  decide   -> finalize [label="stop +\ntranscript has\nTOOL_RESULT", style=dashed];
  formatter -> fallback [label="empty /\n[FETCH_FAILED]", style=dashed, color="#CD4246", fontcolor="#FFA0A0"];
  fallback -> chunker;
  finalize -> chunker -> discord;

  // ── Legend ─────────────────────────────────────────────
  subgraph cluster_legend {
    label=<<b><font color="#F6F7F9">Legend</font></b>>;
    style="rounded"; color="#404854"; bgcolor="#1C2127";
    rank=sink;

    leg_prim [label="Primary path", fillcolor="#1F4B99", fontcolor="#FFFFFF"];
    leg_osint[label="NepalOSINT endpoint", fillcolor="#0A6640", fontcolor="#FFFFFF"];
    leg_web  [label="internet_search (world fallback)", fillcolor="#8F398F", fontcolor="#FFFFFF"];
    leg_err  [label="Error / fallback", fillcolor="#5C2223", fontcolor="#FFC0C0"];

    leg_prim -> leg_osint -> leg_web -> leg_err [style=invis];
  }
}
